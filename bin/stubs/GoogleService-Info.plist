<?xml version="1.0" encoding="UTF-8"?>
<!--
  Stub Firebase config used as a fallback when no theme-package
  ships a real GoogleService-Info.plist. bin/apply-brand.cjs copies
  this into ios/App/App/ so Xcode's Copy Bundle Resources phase has
  a file to bundle. The Info.plist sets FirebaseDataCollectionDefaultEnabled=false
  so Firebase Core stays dormant after configure() with these stub
  credentials.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>AIzaSyA00000000000000000000000000000000</string>
	<key>BUNDLE_ID</key>
	<string>org.microbit.createai</string>
	<key>GCM_SENDER_ID</key>
	<string>000000000000</string>
	<key>GOOGLE_APP_ID</key>
	<string>1:000000000000:ios:0000000000000000000000</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<false/>
	<key>IS_GCM_ENABLED</key>
	<false/>
	<key>IS_SIGNIN_ENABLED</key>
	<false/>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>PROJECT_ID</key>
	<string>stub</string>
	<key>STORAGE_BUCKET</key>
	<string>stub.appspot.com</string>
</dict>
</plist>
