{
  "name": "ml-trainer",
  "version": "0.7.0-local",
  "private": true,
  "type": "module",
  "license": "MIT",
  "allowScripts": {
    "aws-sdk": false,
    "better-sqlite3@12.6.2": true,
    "fsevents": true,
    "esbuild": true,
    "core-js": false,
    "@sentry/capacitor": false,
    "protobufjs": false,
    "@firebase/util": false
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.18.0"
  },
  "scripts": {
    "build": "npm run panda && tsc && cross-env VITE_VERSION=$npm_package_version vite build",
    "build:apps": "npm run panda && tsc && cross-env VITE_BUILD_MODE=apps VITE_VERSION=$npm_package_version vite build",
    "cap:sync:dev": "cross-env CAP_LOCAL_DEV=1 npx cap sync",
    "ci": "npm run test && npm run lint && npm run build && npx prettier --check src",
    "deploy": "website-deploy-aws",
    "panda": "panda codegen && panda cssgen --outfile src/styled-system.css && node bin/unlayer-panda.mjs",
    "panda:watch": "node bin/panda-dev.mjs",
    "predev": "npm run panda",
    "dev": "cross-env VITE_VERSION=$npm_package_version vite",
    "dev:apps": "cross-env VITE_BUILD_MODE=apps VITE_VERSION=$npm_package_version vite --host",
    "invalidate": "invalidate-cloudfront-distribution",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "postinstall": "patch-package && npm run theme && npm run apply-brand && npm run panda",
    "apply-brand": "node bin/apply-brand.cjs",
    "preview": "vite preview",
    "start": "vite dev",
    "test": "vitest --exclude **/ml4f-output.test.ts",
    "test:e2e": "playwright test --headed",
    "test:e2e:headless": "playwright test",
    "theme:watch": "chakra-cli tokens src/deployment/default/theme.ts --watch",
    "theme": "chakra-cli tokens src/deployment/default/theme.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "i18n:compile": "node bin/tidy-lang.cjs && formatjs compile-folder --ast lang src/messages",
    "ml4f-output": "vitest ml4f-output --run",
    "new-translations": "node bin/new-translations.js"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@chakra-ui/cli": "^2.4.1",
    "@formatjs/cli": "^6.2.7",
    "@pandacss/dev": "^1.11.4",
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3": "^7.4.1",
    "@types/ejs": "^3.1.5",
    "@types/lodash.camelcase": "^4.3.9",
    "@types/lodash.debounce": "^4.0.9",
    "@types/lodash.orderby": "^4.6.9",
    "@types/lodash.upperfirst": "^4.3.9",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/web-worker": "^4.1.9",
    "better-sqlite3": "^12.6.2",
    "cross-env": "^7.0.3",
    "ejs": "^3.1.9",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^24.0.0",
    "lightningcss": "^1.31.1",
    "patch-package": "^8.0.1",
    "playwright": "1.58.2",
    "prettier": "2.8.8",
    "typescript": "^5.4.2",
    "vite": "^6.3.5",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^4.1.9",
    "vitest-dom": "^0.1.1"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.0.0",
    "@capacitor-firebase/analytics": "^7.5.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@chakra-ui/icons": "^2.2.4",
    "@chakra-ui/react": "^2.10.10",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@formatjs/intl-localematcher": "^0.8.0",
    "@microbit/capacitor-community-nordic-dfu": "^8.0.0-microbit.1",
    "@microbit/capacitor-sqlite-vanilla": "^0.1.0",
    "@microbit/makecode-embed": "^0.0.0-noproject.76",
    "@microbit/microbit-connection": "^1.0.0-beta.2",
    "@microbit/ml-header-generator": "^0.4.3",
    "@microbit/ml4f": "^2.0.0-beta.0",
    "@microbit/smoothie": "^1.37.0-microbit.2",
    "@sentry/capacitor": "^4.0.0",
    "@tensorflow/tfjs": "^4.20.0",
    "@tensorflow/tfjs-backend-wasm": "^4.20.0",
    "@types/w3c-web-serial": "^1.0.6",
    "@types/w3c-web-usb": "^1.0.6",
    "bowser": "^2.11.0",
    "chart.js": "^4.2.1",
    "fake-indexeddb": "^6.2.5",
    "firebase": "^11.10.0",
    "framer-motion": "^10.2.4",
    "idb": "^8.0.3",
    "lodash.camelcase": "^4.3.0",
    "lodash.debounce": "^4.0.8",
    "lodash.orderby": "^4.6.0",
    "lodash.upperfirst": "^4.3.1",
    "nrf-intel-hex": "^1.4.0",
    "react": "^18.3.1",
    "react-aria-components": "^1.19.0",
    "react-dom": "^18.3.1",
    "react-hotkeys-hook": "^4.6.1",
    "react-icons": "^4.12.0",
    "react-intl": "^6.6.8",
    "react-router": "^6.24.0",
    "react-router-dom": "^6.24.0",
    "swiper": "^12.0.3",
    "uuid": "^13.0.0",
    "zustand": "^4.5.5"
  }
}
